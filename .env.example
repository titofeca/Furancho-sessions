# =======================================
# FURANCHO SESSIONS NFT — CONFIGURACIÓN
# =======================================
# Copia este archivo como .env y rellena los valores

# --- SERVIDOR ---
PORT=3000
BASE_URL=http://localhost:3000

# --- CONTRASEÑA DEL PANEL ADMIN ---
ADMIN_PASSWORD=furancho2024

# --- CROSSMINT API ---
# Obtén tu API key en: https://www.crossmint.com/console/projects/apiKeys
# Tipo: Server-side key (con permiso de minting)
CROSSMINT_API_KEY=your_crossmint_server_api_key_here

# ID de tu colección ERC-1155 en Crossmint
# Lo obtienes al crear la colección en: https://www.crossmint.com/console/collections
CROSSMINT_COLLECTION_ID=your_collection_id_here

# Entorno: "staging" para pruebas, "production" para el evento real
# En staging puedes mintear gratis sin gastar dinero real
CROSSMINT_ENV=staging

# --- EMAIL (para notificaciones a holders) ---
# Usa Gmail con "Contraseñas de aplicación" (no tu contraseña normal)
# Guía: https://support.google.com/accounts/answer/185833
EMAIL_FROM=tu_email@gmail.com
EMAIL_PASSWORD=tu_app_password_de_gmail

# --- MODO DEMO ---
# Pon "true" para probar sin Crossmint real (datos de prueba)
DEMO_MODE=true
